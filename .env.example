APP_NAME=AykAI
APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=INFO

#放你自己的key和模型～，支持阿里云等api
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=
OPENAI_CHAT_MODEL=
OPENAI_BASE_URL=

MILVUS_URI=http://localhost:19530
MILVUS_DB_NAME=default
MILVUS_CHILD_COLLECTION=rag_child_chunks
MILVUS_VECTOR_DIM=1536
MILVUS_METRIC_TYPE=COSINE

ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=rag_child_chunks
ELASTICSEARCH_VECTOR_DIM=1536
ELASTICSEARCH_BULK_BATCH_SIZE=500

BM25_FALLBACK_WARMUP_LIMIT=10000
BM25_FALLBACK_WARMUP_BATCH_SIZE=500

INGEST_WRITE_RETRY_ATTEMPTS=2

POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/AykAI

RETRIEVAL_VECTOR_TOP_K=20
RETRIEVAL_BM25_TOP_K=20
RETRIEVAL_FINAL_TOP_K=8
RETRIEVAL_FUSION_STRATEGY=rrf
RETRIEVAL_RRF_K=60
RETRIEVAL_VECTOR_WEIGHT=0.6
RETRIEVAL_BM25_WEIGHT=0.4
RETRIEVAL_SCORE_THRESHOLD=0.0
RETRIEVAL_DEDUP_BY=parent_id
