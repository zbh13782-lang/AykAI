# App
APP_NAME=AykAI
APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log

# OpenAI-compatible LLM provider
# Fill with your own credentials and model names
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=
OPENAI_CHAT_MODEL=

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_DB_NAME=default
MILVUS_CHILD_COLLECTION=rag_child_chunks
MILVUS_VECTOR_DIM=1024
MILVUS_METRIC_TYPE=COSINE

# Retrieval
RETRIEVAL_VECTOR_TOP_K=20
RETRIEVAL_BM25_TOP_K=20
RETRIEVAL_FINAL_TOP_K=8
RETRIEVAL_FUSION_STRATEGY=weighted
RETRIEVAL_VECTOR_WEIGHT=0.6
RETRIEVAL_BM25_WEIGHT=0.4
RETRIEVAL_SCORE_THRESHOLD=0.0
RETRIEVAL_DEDUP_BY=parent_id

# Local snapshot for BM25 docs
BM25_SNAPSHOT_PATH=.cache/bm25_docs.json

# Postgres
# Keep this aligned with docker-compose defaults unless you customize compose env vars
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/AykAI
