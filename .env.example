# App common
APP_NAME=AykAI
APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=INFO

# Shared model settings
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_NAME=qwen-plus
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Internal gateway key (Go -> Python)
INTERNAL_SERVICE_KEY=dev-internal-key

# Python retrieval and storage settings
MILVUS_URI=http://milvus:19530
MILVUS_DB_NAME=default
MILVUS_CHILD_COLLECTION=rag_child_chunks
MILVUS_VECTOR_DIM=1536
MILVUS_METRIC_TYPE=COSINE
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=rag_child_chunks
ELASTICSEARCH_VECTOR_DIM=1536
ELASTICSEARCH_BULK_BATCH_SIZE=500
BM25_FALLBACK_WARMUP_LIMIT=10000
BM25_FALLBACK_WARMUP_BATCH_SIZE=500
INGEST_WRITE_RETRY_ATTEMPTS=2
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/AykAI
RETRIEVAL_VECTOR_TOP_K=20
RETRIEVAL_BM25_TOP_K=20
RETRIEVAL_FINAL_TOP_K=8
RETRIEVAL_FUSION_STRATEGY=rrf
RETRIEVAL_RRF_K=60
RETRIEVAL_VECTOR_WEIGHT=0.6
RETRIEVAL_BM25_WEIGHT=0.4
RETRIEVAL_SCORE_THRESHOLD=0.0
RETRIEVAL_DEDUP_BY=parent_id

# Database defaults
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=GopherAI
POSTGRES_DB=AykAI
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
